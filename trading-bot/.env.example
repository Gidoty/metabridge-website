# Binance API credentials
# Testnet keys: generate at https://testnet.binancefuture.com (separate account from mainnet)
# Mainnet keys: only needed once you deliberately switch USE_TESTNET=false
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Safety switch. Must stay "true" until you have validated the strategy
# on testnet/paper trading and are ready to risk real funds.
USE_TESTNET=true

# Second, independent confirmation required to place real orders.
# Leave blank/unset for testnet or dry-run. To go live, set this to
# exactly: I_UNDERSTAND_THE_RISK
LIVE_TRADING_CONFIRMED=

# When true, no orders are sent anywhere (not even testnet) - the bot only
# logs what it would have done. Useful for a first smoke-test run.
DRY_RUN=true

# Market to trade (ccxt unified symbol for Binance USDM futures)
SYMBOL=BTC/USDT:USDT
TIMEFRAME=15m

# Optional: Telegram alerts on trade open/close/errors
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Phone/web dashboard (dashboard.py). Binds to localhost only by default -
# see trading-bot/deploy/DEPLOY.md for how to reach it from your phone
# (SSH tunnel, or a reverse proxy for a real HTTPS URL). A username and
# password are REQUIRED - the dashboard refuses to start without both,
# since it will otherwise be an unauthenticated window into your account.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
