# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# Never commit the actual .env file — it's already in .gitignore.
# ═══════════════════════════════════════════════════════════════════

# Anthropic API key — powers FAQ answering, summarisation, moderation
# judgment, and nudge generation. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Comma-separated WhatsApp numbers (country code + number, NO + or spaces)
# that are allowed to issue admin commands in DM, e.g. !addmaterial
# Example: ADMIN_NUMBERS=2348012345678,2347098765432
ADMIN_NUMBERS=

# The WhatsApp group JID this bot manages. You won't know this until
# the bot is running once — see README "Finding a Group ID".
# Format looks like: 123456789012345678@g.us
COHORT_GROUP_ID=

# IANA timezone for all scheduled messages.
TIMEZONE=Africa/Lagos

# Where the SQLite database file is stored.
DB_PATH=./data/metabridge.db

# Logging verbosity: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to "production" when running under PM2 on a server. This switches
# the logger to raw JSON output (no colours, no pino-pretty overhead)
# so PM2 can capture and rotate the logs cleanly.
NODE_ENV=production
